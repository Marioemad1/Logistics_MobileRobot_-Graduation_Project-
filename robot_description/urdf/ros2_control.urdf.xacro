    <ros2_control name="MobileBase" type="system">
        
        <hardware>
            <plugin>mobile_base_hardware/MobileBaseHardWare</plugin>
        </hardware>
        <joint name="base_right_wheel_joint">
            <command_interface name="velocity" />
            <state_interface name="position"  />
            <state_interface name="velocity" />
        </joint>
        <joint name="base_left_wheel_joint">
            <command_interface name="velocity" />
            <state_interface name="position"  />
            <state_interface name="velocity" />
        </joint>
    </ros2_control>


    
    <ros2_control name="NemaSystem" type="system">
        <hardware>
            <plugin>nema_lift_hardware_interface/NemaLiftHardwareInterface</plugin> 
        </hardware>

        <joint name="base_esp_joint">
            <command_interface name="state"/>
            <state_interface name="state"/>
        </joint>
    </ros2_control>


    
</robot>